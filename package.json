{
  "name": "odysseia-forum-web",
  "version": "2.3.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "ANALYZE_BUNDLE=true vite build",
    "preview": "vite preview",
    "lint": "eslint . --report-unused-disable-directives",
    "lint:ox": "oxlint . --deny-warnings",
    "lint:styles": "stylelint \"src/**/*.{css,tsx}\" --allow-empty-input",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "gen:api": "python3 scripts/export_openapi.py && npx openapi-typescript openapi.json -o src/shared/types/openapi.d.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.3",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-virtual": "^3.13.0",
    "@types/three": "^0.183.1",
    "ahooks": "^3.7.10",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.57.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.22.0",
    "remark-gfm": "^4.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.0",
    "three": "^0.183.2",
    "yaml": "^2.8.3",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.3",
    "@tanstack/react-query-devtools": "^5.99.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.2",
    "baseline-browser-mapping": "^2.8.19",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.0.1",
    "openapi-typescript": "^7.13.0",
    "oxlint": "^1.61.0",
    "prettier": "^3.2.5",
    "stylelint": "^17.8.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "tailwindcss": "^4.2.3",
    "tailwindcss-animate": "^1.0.7",
    "ts-morph": "^27.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.9",
    "vite-bundle-analyzer": "^1.3.7",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "overrides": {
      "ahooks>react": "^19.0.0"
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "chrome >= 100",
    "safari >= 15",
    "edge >= 100"
